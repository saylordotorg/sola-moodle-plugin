{{!
    @template local_ai_course_assistant/chat_message

    Single chat message bubble.

    Context variables required for this template:
    * role - Message role (user or assistant)
    * message - The message HTML content
}}
<div class="local-ai-course-assistant__message local-ai-course-assistant__message--{{role}}" data-role="{{role}}">
    <div class="local-ai-course-assistant__message-content">
        {{{message}}}
    </div>
</div>
